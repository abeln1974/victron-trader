# Victron - Modbus-TCP (anbefalt for Abelgard)
# Aktiver på Cerbo GX: Settings → Services → Modbus-TCP → Enabled
# Port 502 (standard Modbus-TCP)
# Unit-ID 246 for VE.Bus (MultiPlus/Quattro)
# Unit-ID 100 for System (SOC, etc)

# Home Assistant - for Qubino 3-fase smartmåler (primærkilde grid L1+L2+L3)
# Generer token: HA → Profil → Langsiktige tilgangstokener
HA_URL=https://homeassistant.abelgaard.no
HA_TOKEN=
HA_TIMEOUT=3.0

VICTRON_HOST=192.168.1.60
VICTRON_MODBUS_PORT=502

# VRM API (cloud backup) - Abelgard site ID 411797
# Hent token fra https://vrm.victronenergy.com → Preferences → Integrations
VRM_TOKEN=
VRM_SITE_ID=411797

# Strømmarked - Abelgard er i NO1 (Øst-Norge)
PRICE_AREA=NO1
VAT=1.25

# Batterikonfig - Abelgard: 4x12.5kWh NMC = 50kWh total
# 2x MultiPlus-II 48/5000 = 10kW max (5kW hver)
BATTERY_CAPACITY_KWH=45.6          # SmartShunt: 800Ah × 57V = 45.6 kWh brutto
BATTERY_MAX_CHARGE_KW=10
BATTERY_MAX_DISCHARGE_KW=10
BATTERY_EFFICIENCY=0.95
# ESS: Optimized without BatteryLife, NMC: hold 20-90% for lang levetid
MIN_SOC=20                           # NMC konservativ (Victron floor er 10%)
MAX_SOC=90                           # NMC: unngå langvarig >90%

# Strømprisstruktur (fra Kraftriket Solstrøm-faktura)
# Innkjøp: Spotpris + påslag + nettleie + avgifter
SUPPLIER_MARKUP_ORE=6.50         # Kraftriket påslag øre/kWh eks mva
GRID_TARIFF_DAY_ORE=16.50        # Nettleie dag øre/kWh EKS mva (Føie AS: 20.63 inkl mva)
GRID_TARIFF_NIGHT_ORE=10.00      # Nettleie natt øre/kWh EKS mva (Føie AS: 12.50 inkl mva)
CONSUMPTION_TAX_ORE=7.13         # Forbruksavgift øre/kWh eks mva (8.91 inkl mva)
ENOVA_ORE=1.00                   # Enova-avgift øre/kWh eks mva (1.25 inkl mva)
CAPACITY_CHARGE_NOK=662.50       # Kapasitetsledd kr/mnd (10-15kW trinn, faktisk apr 2026)
NET_SELL_BACK_ORE=6.25           # Føie AS tilbakebetaling produsert energi øre/kWh

# Salg (plusskunde) - Kraftriket betaler dette eks mva
SELL_PRICE_ORE=75.00             # Øre/kWh du får ved salg

# Dag-tariff: 06:00-22:00, Natt: 22:00-06:00

# EVCS elbil-lader (Victron EVCS via Home Assistant)
EVCS_ENTITY_PREFIX=evcs_hq2309vtvnf  # Prefix for alle EVCS-entiteter i HA
EVCS_MIN_CURRENT_A=6                  # Min ladestrøm (A) — EVCS-standard
EVCS_MAX_CURRENT_A=16                 # Max vi tillater (16A × 230V = 3.7kW, 1-fase)
EVCS_PHASES=1                         # 1-fase koblet
PEAK_LIMIT_KW=9.5                     # Max grid-import inkl EVCS (buffer til 10kW-trinnet)
DAY_TARIFF_START=6
DAY_TARIFF_END=22

# Sol (Fronius Primo 5kW AC-coupled på Abelgård)
SOLAR_MAX_KW=5.0
SOLAR_THRESHOLD_KW=0.5

# Strategi
MIN_PRICE_DIFF_NOK=0.30
FORECAST_HOURS=24

# Logging
DB_PATH=./data/profit.db
LOG_LEVEL=INFO
